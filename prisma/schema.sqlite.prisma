// SQLite 开发版本 Schema
// 用于本地快速测试

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  name          String
  password      String
  wechatQrCode  String
  wechatId      String?
  emailContact  String?
  isApproved    Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  newsPosts     News[]
  shares        Share[]

  @@map("users")
}

model News {
  id            String    @id @default(cuid())
  title         String
  summary       String
  content       String
  category      String
  source        String
  sourceUrl     String?
  imageUrl      String?
  tags          String    @default("")

  status        String    @default("PENDING")
  submittedBy   String
  submitter     User      @relation(fields: [submittedBy], references: [id])
  submittedAt   DateTime  @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNote    String?

  scheduledAt   DateTime?
  publishedAt   DateTime?

  viewCount     Int       @default(0)
  shareCount    Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shares        Share[]

  @@map("news")
}

model Share {
  id            String    @id @default(cuid())
  newsId        String
  news          News      @relation(fields: [newsId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  shareType     String
  shareUrl      String

  createdAt     DateTime  @default(now())

  @@map("shares")
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  type          String
  title         String
  content       String
  newsId        String?
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@map("notifications")
}
